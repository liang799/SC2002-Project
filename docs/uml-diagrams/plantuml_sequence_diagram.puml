@startuml sd_SC2002_CustomMode_Walkthrough
title sd SC2002 Runtime Battle Flow - Custom Mode Walkthrough 
autonumber
autoactivate on
skinparam shadowing false
skinparam ParticipantPadding 20
skinparam BoxPadding 10
skinparam actorBackgroundColor #DDF3F7

actor "u:User" as U
boundary "ui:TurnBasedArenaGui" as UI
control "bc:BattleController" as BC
control "bsf:BattleSetupFactory" as BSF
control "be:BattleEngine" as BE
control "tp:DefaultTurnProcessor" as TP
control "dp:GuiPlayerDecisionProvider" as DP
control "blr:BattleLaunchRequest" as BLR
control "wm:DefaultWaveManager" as WM
control "tos:SpeedTurnOrderStrategy" as TOS
entity "wizard:PlayerCharacter" as W
entity "inv:Inventory" as INV
entity "GA:Goblin" as GA
entity "GB:Goblin" as GB
entity "GC:Goblin" as GC

note over BE
Damage formula: damage = max(0, attackUsed - targetDefense), then status modifiers.
Smoke Bomb blocks the next 2 enemy-origin attacks.
Defend adds +10 DEF for 2 rounds.
Cooldown decreases before each player action that advances cooldown.
end note

== Setup ==
U -> UI : launch GUI app
UI --> BC : <<create>> BattleController(this, setupFactory)
UI -> U : show setup panel

U -> UI : select WIZARD
U -> UI : select POTION, SMOKE_BOMB
U -> UI : configure Wave 1 (Goblin x1)
U -> UI : configure Wave 2 (Goblin x2)
UI -> BLR : custom(CustomGameConfiguration)
BLR --> UI : BattleLaunchRequest
U -> UI : click Start Battle
UI -> BC : startBattle(BattleLaunchRequest)

BC -> UI : clearBattleLog()
BC -> UI : setSetupControlsEnabled(false)
BC -> UI : showBattleLoading()
BC -> BLR : createSetup(BSF)
BLR -> BSF : createCustom(CustomGameConfiguration)

BSF -> W : createPlayer(WIZARD)
BSF -> INV : populateInventory(POTION=1, SMOKE_BOMB=1)
create GA
BSF --> GA : <<create>> createEnemy(GOBLIN, "Goblin A")
create GB
BSF --> GB : <<create>> createEnemy(GOBLIN, "Goblin B") [reserve]
create GC
BSF --> GC : <<create>> createEnemy(GOBLIN, "Goblin C") [reserve]
BSF --> BLR : BattleSetup
BLR --> BC : BattleSetup

BC -> UI : showBattleLoaded(BattleSetup)
BC --> DP : <<create>> GuiPlayerDecisionProvider(this)
BC --> BE : <<create>> BattleEngine(BattleSetup, SpeedTurnOrderStrategy)
BC -> BE : runUntilBattleEnds(DP, battleEventListener)

note over DP,BC
GUI runtime decision flow:
GuiPlayerDecisionProvider -> BattleController.awaitPlayerDecision -> command resolution.
This sequence models one concrete custom battle walkthrough.
end note

== Round 1 ==
group Round 1
  BE -> TOS : determineOrder([GA, W])
  TOS --> BE : [GA, W]

  BE -> TP : processTurn(round=1, actor=GA, DP, context, emit)
  TP -> GA : takeTurn(context, target=W)
  GA -> W : attack(target=W, attackPower=35)
  W --> GA : AttackResolution(damage=25, hpAfter=175)
  GA --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=175)

  BE -> TP : processTurn(round=1, actor=W, DP, context, emit)
  TP -> DP : decide(1, W, [GA])
  DP -> UI : showPlayerTurn(1)
  UI -> U : choose SpecialSkill(Arcane Blast)
  UI --> DP : PlayerDecision(UseSpecialSkillAction)
  DP --> TP : PlayerDecision(UseSpecialSkillAction)
  TP -> W : advanceRoundState(cooldown 0 to 0)
  TP -> W : useSpecialSkill(context, target=none)
  W -> GA : attack(target=GA, attackPower=50)
  GA --> W : AttackResolution(damage=35, hpAfter=20)
  W --> TP : ActionEvent(Arcane Blast, damage=35, goblinAHp=20)

  note over BE
  End R1: Wizard 175/200, Goblin A 20, Potion 1, Smoke Bomb 1, CD 3.
  end note
end

== Round 2 ==
group Round 2
  BE -> TP : processTurn(round=2, actor=GA, DP, context, emit)
  TP -> GA : takeTurn(context, target=W)
  GA -> W : attack(target=W, attackPower=35)
  W --> GA : AttackResolution(damage=25, hpAfter=150)
  GA --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=150)

  BE -> TP : processTurn(round=2, actor=W, DP, context, emit)
  TP -> DP : decide(2, W, [GA])
  DP -> UI : showPlayerTurn(2)
  UI -> U : press SpecialSkill (CD 3) -> cooldown message, then choose BasicAttack target=GA
  UI --> DP : PlayerDecision(BasicAttackAction, GA)
  DP --> TP : PlayerDecision(BasicAttackAction, GA)
  note over DP
  Scenario step: SpecialSkill is attempted during cooldown,
  cooldown feedback is shown, then BasicAttack is selected.
  end note
  TP -> W : advanceRoundState(cooldown 3 to 2)
  TP -> W : execute BasicAttackAction(GA)
  W -> GA : attack(target=GA, attackPower=50)
  GA --> W : AttackResolution(damage=35, hpAfter=0, eliminated=true)
  W --> TP : ActionEvent(BasicAttack, damage=35, goblinAHp=0)

  BE -> WM : spawnBackupIfNeeded(emit)
  WM --> BE : NarrationEvent(Backup Spawn triggered: Goblin B, Goblin C)

  note over BE
  End R2: Wizard 150/200, Goblin A 0, Goblin B 55, Goblin C 55, CD 2.
  end note
end

== Round 3 ==
group Round 3
  BE -> TOS : determineOrder([GB, GC, W])
  TOS --> BE : [GB, GC, W]

  BE -> TP : processTurn(round=3, actor=GB, DP, context, emit)
  TP -> GB : takeTurn(context, target=W)
  GB -> W : attack(target=W, attackPower=35)
  W --> GB : AttackResolution(damage=25, hpAfter=125)
  GB --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=125)

  BE -> TP : processTurn(round=3, actor=GC, DP, context, emit)
  TP -> GC : takeTurn(context, target=W)
  GC -> W : attack(target=W, attackPower=35)
  W --> GC : AttackResolution(damage=25, hpAfter=100)
  GC --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=100)

  BE -> TP : processTurn(round=3, actor=W, DP, context, emit)
  TP -> DP : decide(3, W, [GB, GC])
  DP -> UI : showPlayerTurn(3)
  UI -> U : choose Item(Smoke Bomb)
  UI --> DP : PlayerDecision(UseSmokeBombAction)
  DP --> TP : PlayerDecision(UseSmokeBombAction)
  TP -> W : advanceRoundState(cooldown 2 to 1)
  TP -> INV : use(SMOKE_BOMB)
  TP -> W : addStatusEffect(SmokeBombStatusEffect(2))
  W --> TP : NarrationEvent(Smoke Bomb used)

  note over BE
  End R3: Wizard 100/200, Goblin B 55, Goblin C 55, Potion 1, Smoke Bomb 0, CD 1.
  end note
end

== Round 4 ==
group Round 4
  BE -> TP : processTurn(round=4, actor=GB, DP, context, emit)
  TP -> GB : takeTurn(context, target=W)
  GB -> W : attack(target=W, attackPower=35)
  W --> GB : AttackResolution(damage=0, hpAfter=100, note=Smoke Bomb blocked the attack)
  GB --> TP : ActionEvent(BasicAttack, damage=0, wizardHp=100)

  BE -> TP : processTurn(round=4, actor=GC, DP, context, emit)
  TP -> GC : takeTurn(context, target=W)
  GC -> W : attack(target=W, attackPower=35)
  W --> GC : AttackResolution(damage=0, hpAfter=100, note=Smoke Bomb blocked the attack)
  GC --> TP : ActionEvent(BasicAttack, damage=0, wizardHp=100, note=Smoke Bomb expired)

  BE -> TP : processTurn(round=4, actor=W, DP, context, emit)
  TP -> DP : decide(4, W, [GB, GC])
  DP -> UI : showPlayerTurn(4)
  UI -> U : choose Defend
  UI --> DP : PlayerDecision(DefendAction)
  DP --> TP : PlayerDecision(DefendAction)
  TP -> W : advanceRoundState(cooldown 1 to 0)
  TP -> W : addStatusEffect(DefendStatusEffect(2))
  W --> TP : StatusEffectOutcome(DEF +10, duration=2 rounds)

  note over BE
  End R4: Wizard 100/200, Goblin B 55, Goblin C 55, DEFENDING, CD 0.
  end note
end

== Round 5 ==
group Round 5
  BE -> TP : processTurn(round=5, actor=GB, DP, context, emit)
  TP -> GB : takeTurn(context, target=W)
  GB -> W : attack(target=W, attackPower=35)
  W --> GB : AttackResolution(damage=15, hpAfter=85, defenseApplied=20)
  GB --> TP : ActionEvent(BasicAttack, damage=15, wizardHp=85)

  BE -> TP : processTurn(round=5, actor=GC, DP, context, emit)
  TP -> GC : takeTurn(context, target=W)
  GC -> W : attack(target=W, attackPower=35)
  W --> GC : AttackResolution(damage=15, hpAfter=70, defenseApplied=20)
  GC --> TP : ActionEvent(BasicAttack, damage=15, wizardHp=70)

  BE -> TP : processTurn(round=5, actor=W, DP, context, emit)
  TP -> DP : decide(5, W, [GB, GC])
  DP -> UI : showPlayerTurn(5)
  UI -> U : choose Item(Potion)
  UI --> DP : PlayerDecision(UsePotionAction)
  DP --> TP : PlayerDecision(UsePotionAction)
  TP -> W : advanceRoundState(cooldown 0 to 0)
  TP -> INV : use(POTION)
  TP -> W : heal(amount=100)
  W --> TP : NarrationEvent(Wizard -> Item -> Potion used: HP: 70 -> 170 (+100))

  note over BE
  End R5: Wizard 170/200, Goblin B 55, Goblin C 55, Potion 0, Smoke Bomb 0, CD 0.
  end note
end

== Round 6 ==
group Round 6
  BE -> TP : processTurn(round=6, actor=GB, DP, context, emit)
  TP -> GB : takeTurn(context, target=W)
  GB -> W : attack(target=W, attackPower=35)
  W --> GB : AttackResolution(damage=25, hpAfter=145)
  GB --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=145)

  BE -> TP : processTurn(round=6, actor=GC, DP, context, emit)
  TP -> GC : takeTurn(context, target=W)
  GC -> W : attack(target=W, attackPower=35)
  W --> GC : AttackResolution(damage=25, hpAfter=120)
  GC --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=120)

  BE -> TP : processTurn(round=6, actor=W, DP, context, emit)
  TP -> DP : decide(6, W, [GB, GC])
  DP -> UI : showPlayerTurn(6)
  UI -> U : choose SpecialSkill(Arcane Blast)
  UI --> DP : PlayerDecision(UseSpecialSkillAction)
  DP --> TP : PlayerDecision(UseSpecialSkillAction)
  TP -> W : advanceRoundState(cooldown 0 to 0)
  TP -> W : useSpecialSkill(context, target=none)
  W -> GB : attack(target=GB, attackPower=50)
  GB --> W : AttackResolution(damage=35, hpAfter=20)
  W -> GC : attack(target=GC, attackPower=50)
  GC --> W : AttackResolution(damage=35, hpAfter=20)
  W --> TP : ActionEvent(Arcane Blast, goblinBHp=20, goblinCHp=20)

  note over BE
  End R6: Wizard 120/200, Goblin B 20, Goblin C 20, CD 3.
  end note
end

== Round 7 ==
group Round 7
  BE -> TP : processTurn(round=7, actor=GB, DP, context, emit)
  TP -> GB : takeTurn(context, target=W)
  GB -> W : attack(target=W, attackPower=35)
  W --> GB : AttackResolution(damage=25, hpAfter=95)
  GB --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=95)

  BE -> TP : processTurn(round=7, actor=GC, DP, context, emit)
  TP -> GC : takeTurn(context, target=W)
  GC -> W : attack(target=W, attackPower=35)
  W --> GC : AttackResolution(damage=25, hpAfter=70)
  GC --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=70)

  BE -> TP : processTurn(round=7, actor=W, DP, context, emit)
  TP -> DP : decide(7, W, [GB, GC])
  DP -> UI : showPlayerTurn(7)
  UI -> U : choose BasicAttack, target=GB
  UI --> DP : PlayerDecision(BasicAttackAction, GB)
  DP --> TP : PlayerDecision(BasicAttackAction, GB)
  TP -> W : advanceRoundState(cooldown 3 to 2)
  TP -> W : execute BasicAttackAction(GB)
  W -> GB : attack(target=GB, attackPower=50)
  GB --> W : AttackResolution(damage=35, hpAfter=0, eliminated=true)
  W --> TP : ActionEvent(BasicAttack, damage=35, goblinBHp=0)

  note over BE
  End R7: Wizard 70/200, Goblin B 0, Goblin C 20, CD 2.
  end note
end

== Round 8 ==
group Round 8
  BE -> TP : processTurn(round=8, actor=GC, DP, context, emit)
  TP -> GC : takeTurn(context, target=W)
  GC -> W : attack(target=W, attackPower=35)
  W --> GC : AttackResolution(damage=25, hpAfter=45)
  GC --> TP : ActionEvent(BasicAttack, damage=25, wizardHp=45)

  BE -> TP : processTurn(round=8, actor=W, DP, context, emit)
  TP -> DP : decide(8, W, [GC])
  DP -> UI : showPlayerTurn(8)
  UI -> U : choose BasicAttack, target=GC
  UI --> DP : PlayerDecision(BasicAttackAction, GC)
  DP --> TP : PlayerDecision(BasicAttackAction, GC)
  TP -> W : advanceRoundState(cooldown 2 to 1)
  TP -> W : execute BasicAttackAction(GC)
  W -> GC : attack(target=GC, attackPower=50)
  GC --> W : AttackResolution(damage=35, hpAfter=0, eliminated=true)
  W --> TP : ActionEvent(BasicAttack, damage=35, goblinCHp=0)

  BE --> BC : NarrationEvent(Victory:)
  BE --> BC : NarrationEvent(Remaining HP: 45 / 200)
  BE --> BC : NarrationEvent(Total Rounds: 8)
  BE --> BC : NarrationEvent(Remaining Potion: 0)
  BE --> BC : NarrationEvent(Remaining Smoke Bomb: 0)
  BC -> UI : showBattleEvent(event, battleMessage, transcriptLines)
  UI -> U : print final transcript lines

  note over BE
  End R8: Victory with high-coverage gameplay flow.
  end note
end

== Post game ==
BC -> UI : askPostGameChoice()
UI -> U : promptPostGameChoice(Replay, New Setup, Exit)
U --> UI : Exit
UI --> BC : PostGameChoice(EXIT)
BC -> UI : exitGame()

@enduml
