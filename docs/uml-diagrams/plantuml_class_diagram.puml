@startuml
title SC2002 Turn-Based Combat Arena - Production Class Diagram

left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
hide circle

legend left
  SC2002 Project
  Members: Larry, Neoh, Nestor, Madhavan
endlegend

package "bootstrap" {
  class CombatantFactories <<factory>> <<utility>> {
    {static} +createDefault(statusEffectRegistryFactory: StatusEffectRegistryFactory, basicAttackAction: BattleAction, shieldBashAction: BattleAction, arcaneBlastAction: BattleAction): CombatantFactory
  }
}

package "domain" {
  abstract class Combatant <<entity>> {
    - combatantId: CombatantId
    - name: String
    - baseStats: CombatStats
    - inventory: Inventory
    - hitPoints: HitPoints
    - statusEffectRegistry: StatusEffectRegistry
    + combatantId(): CombatantId
    + getName(): String
    + getCurrentHp(): int
    + getMaxHp(): int
    + getHitPoints(): HitPoints
    + getInventory(): Inventory
    + getAttack(): int
    + getBaseAttack(): int
    + getDefense(): int
    + getSpeed(): int
    + isAlive(): boolean
    + attack(target: Combatant): AttackResolution
    + attack(target: Combatant, attackPower: int): AttackResolution
    + getStat(statType: StatType): int
    + receiveDamage(damage: int): void
    + heal(amount: int): void
    + addStatusEffect(statusEffect: StatusEffect): List<CombatantStatusOutcome>
    + getTurnBlockReason(): Optional<String>
    + consumeStatusEffectOutcomes(): List<CombatantStatusOutcome>
    + completeRound(): List<CombatantStatusOutcome>
    + getActiveStatuses(): List<String>
  }

  class PlayerCharacter <<entity>> {
    - specialSkill: SpecialSkill
    + specialSkillTargetingMode(): TargetingMode
    + getSpecialSkillCooldown(): int
    + canUseSpecialSkill(): boolean
    + useSpecialSkill(context: ActionExecutionContext, target: Combatant): List<BattleEvent>
    + useSpecialSkillWithoutCooldown(context: ActionExecutionContext, target: Combatant): List<BattleEvent>
    + getSpecialSkillName(): String
    + advanceRoundState(): void
  }

  class EnemyCombatant <<entity>> {
    - turnAction: BattleAction
    + takeTurn(context: ActionExecutionContext, target: Combatant): List<BattleEvent>
  }

  class Inventory <<entity>> {
    - itemCounts: Map<ItemType, Integer> [0..*]
    + add(itemType: ItemType, count: int): void
    + countOf(itemType: ItemType): int
    + use(itemType: ItemType): void
    + snapshot(): Map<ItemType, Integer>
  }

  class SpecialSkill <<entity>> {
    - action: BattleAction
    - cooldownTurns: int
    - cooldownRemaining: int
    + actionName(): String
    + targetingMode(actor: Combatant): TargetingMode
    + isAvailable(): boolean
    + cooldownRemaining(): int
    + use(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
    + useWithoutTriggeringCooldown(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
    + advanceCooldown(): void
    + triggerCooldown(): void
  }

  interface CombatantFactory <<factory>> {
    + createPlayer(playerType: PlayerType): PlayerCharacter
    + createEnemy(enemyType: EnemyType, name: String): EnemyCombatant
  }

  class DefaultCombatantFactory <<factory>> {
    - statusEffectRegistryFactory: StatusEffectRegistryFactory
    - playerCreators: Map<PlayerType, PlayerCharacterCreator>
    - enemyCreators: Map<EnemyType, EnemyCombatantCreator>
    + createPlayer(playerType: PlayerType): PlayerCharacter
    + createEnemy(enemyType: EnemyType, name: String): EnemyCombatant
  }

  interface PlayerCharacterCreator <<factory>> {
    + create(statusEffectRegistry: StatusEffectRegistry): PlayerCharacter
  }

  interface EnemyCombatantCreator <<factory>> {
    + create(name: String, statusEffectRegistry: StatusEffectRegistry): EnemyCombatant
  }

  interface SpecialSkillFactory <<factory>> {
    + create(): SpecialSkill
  }

  class DefaultSpecialSkillFactory <<factory>> {
    - action: BattleAction
    - cooldownTurns: int
    + create(): SpecialSkill
  }

  class AttackResolution <<record>> {
    - attackUsed: int
    - targetDefense: int
    - hpBefore: int
    - hpAfter: int
    - damage: int
    - targetEliminated: boolean
    - statusEffectOutcomes: List<CombatantStatusOutcome> [0..*]
    + appendStatusEffectOutcomes(additionalOutcomes: List<CombatantStatusOutcome>): AttackResolution
  }

  class CombatStats <<record>> {
    - attack: Stat
    - defense: Stat
    - speed: Stat
    + stat(statType: StatType): Stat
    + valueOf(statType: StatType): int
    + withStat(type: StatType, updatedStat: Stat): CombatStats
    + addFlat(type: StatType, amount: int): CombatStats
    + multiplyBy(type: StatType, factor: double): CombatStats
    + clampMinimum(type: StatType, minimum: int): CombatStats
    + modify(type: StatType, modifier: UnaryOperator<Stat>): CombatStats
  }

  class CombatantId <<record>> {
    - value: UUID
    {static} + generate(): CombatantId
    {static} + of(value: UUID): CombatantId
    {static} + of(value: String): CombatantId
  }

  class HitPoints <<record>> {
    - current: int
    - max: int
    {static} + full(maxHp: int): HitPoints
    + takeDamage(damage: int): HitPoints
    + heal(amount: int): HitPoints
    + isDead(): boolean
    + getHealthPercentage(): double
  }

  class Stat <<record>> {
    - value: int
    + addFlat(amount: int): Stat
    + multiplyBy(factor: double): Stat
    + clampMinimum(minimum: int): Stat
    + modify(modifier: IntUnaryOperator): Stat
  }

  enum ItemType {
    POTION
    POWER_STONE
    SMOKE_BOMB
    - displayName: String
    - description: String
    + getDisplayName(): String
    + getDescription(): String
  }

  enum StatType {
    ATTACK
    DEFENSE
    SPEED
  }
}

package "domain.status" {
  interface StatusEffect <<strategy>> {
    + kind(): StatusEffectKind
    + description(): String
    + mergeWith(other: StatusEffect): Optional<StatusEffect>
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + onExpire(owner: Combatant): List<StatusEffectOutcome>
    + onRoundEnd(owner: Combatant): List<StatusEffectOutcome>
    + modifyStats(stats: CombatStats): CombatStats
    + modifyIncomingDamage(owner: Combatant, attacker: Combatant, damage: int): DamageAdjustment
    + getTurnBlockReason(owner: Combatant): Optional<String>
    + isExpired(): boolean
  }

  class StatusEffectRegistry <<entity>> {
    - effects: List<StatusEffect> [0..*]
    - pendingOutcomes: List<StatusEffectOutcome> [0..*]
    + add(owner: Combatant, statusEffect: StatusEffect): List<StatusEffectOutcome>
    + adjustIncomingDamage(owner: Combatant, attacker: Combatant, damage: int): DamageAdjustment
    + getTurnBlockReason(owner: Combatant): Optional<String>
    + completeRound(owner: Combatant): List<StatusEffectOutcome>
    + activeStatuses(owner: Combatant): List<String>
    + apply(owner: Combatant, stats: CombatStats): CombatStats
    + consumeOutcomes(): List<StatusEffectOutcome>
  }

  interface StatusEffectRegistryFactory <<factory>> {
    + create(): StatusEffectRegistry
  }

  class DefaultStatusEffectRegistryFactory <<factory>> {
    - statusEffectRegistrySupplier: Supplier<StatusEffectRegistry>
    + create(): StatusEffectRegistry
  }

  interface StatusEffectOutcome {
    + source(): StatusEffectKind
  }

  class CombatantStatusOutcome <<record>> {
    - combatantId: CombatantId
    - combatantName: String
    - outcome: StatusEffectOutcome
  }

  class DamageAdjustment <<record>> {
    - damage: int
    - modifiers: List<DamageModifier> [0..*]
    {static} + unchanged(damage: int): DamageAdjustment
  }

  class DamageModifier <<record>> {
    - source: StatusEffectKind
    - type: DamageModifierType
  }

  class StatusEffectChange <<record>> {
    - source: StatusEffectKind
    - type: StatusEffectChangeType
    - magnitude: int
    - duration: int
    {static} + applied(source: StatusEffectKind): StatusEffectChange
    {static} + applied(source: StatusEffectKind, magnitude: int): StatusEffectChange
    {static} + applied(source: StatusEffectKind, magnitude: int, duration: int): StatusEffectChange
    {static} + expired(source: StatusEffectKind): StatusEffectChange
  }

  enum DamageModifierType {
    BLOCKED
    REDUCED
    INCREASED
  }

  enum StatusEffectChangeType {
    APPLIED
    EXPIRED
  }

  enum StatusEffectKind {
    ARCANE_POWER
    DEFEND
    SMOKE_BOMB
    STRENGTH_BOOST
    STUN
  }

  class ArcanePowerStatusEffect {
    - attackBonus: int
    + kind(): StatusEffectKind
    + description(): String
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + modifyStats(stats: CombatStats): CombatStats
    + mergeWith(other: StatusEffect): Optional<StatusEffect>
    + isExpired(): boolean
  }

  class DefendStatusEffect {
    - roundsRemaining: int
    + kind(): StatusEffectKind
    + description(): String
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + modifyStats(stats: CombatStats): CombatStats
    + onRoundEnd(owner: Combatant): List<StatusEffectOutcome>
    + onExpire(owner: Combatant): List<StatusEffectOutcome>
    + isExpired(): boolean
  }

  class StrengthBoostStatusEffect {
    - attackBonus: int
    - roundsRemaining: int
    + kind(): StatusEffectKind
    + description(): String
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + modifyStats(stats: CombatStats): CombatStats
    + onRoundEnd(owner: Combatant): List<StatusEffectOutcome>
    + onExpire(owner: Combatant): List<StatusEffectOutcome>
    + isExpired(): boolean
  }

  class SmokeBombStatusEffect {
    - chargesRemaining: int
    + kind(): StatusEffectKind
    + description(): String
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + modifyIncomingDamage(owner: Combatant, attacker: Combatant, damage: int): DamageAdjustment
    + onExpire(owner: Combatant): List<StatusEffectOutcome>
    + isExpired(): boolean
  }

  class StunStatusEffect {
    - blockedTurnsRemaining: int
    + kind(): StatusEffectKind
    + description(): String
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + getTurnBlockReason(owner: Combatant): Optional<String>
    + onExpire(owner: Combatant): List<StatusEffectOutcome>
    + isExpired(): boolean
  }
}

package "actions" {
  interface ActionExecutionContext {
    + getLivingEnemies(): List<Combatant>
    + getLivingEnemiesInTurnOrder(): List<Combatant>
  }

  interface BattleAction <<strategy>> {
    + getName(): String
    + advancesCooldown(): boolean
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  enum TargetingMode {
    NONE
    SINGLE_ENEMY
  }

  class BasicAttackAction {
    + getName(): String
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class DefendAction {
    + getName(): String
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class ShieldBashAction {
    + getName(): String
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class ArcaneBlastAction {
    + getName(): String
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UsePotionAction {
    + getName(): String
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UseSmokeBombAction {
    + getName(): String
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UseSpecialSkillAction {
    + getName(): String
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UsePowerStoneSkillAction {
    + getName(): String
    + advancesCooldown(): boolean
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }
}

package "engine" {
  interface BattleEventListener <<observer>> {
    {static} +NO_OP: BattleEventListener
    + onEvent(event: BattleEvent): void
  }

  class BattleEngine <<control>> {
    - battleState: BattleState
    - turnOrderStrategy: TurnOrderStrategy
    - turnProcessor: TurnProcessor
    - waveManager: WaveManager
    - roundLifecycle: RoundLifecycle
    - battleOutcomeReporter: BattleOutcomeReporter
    + runRounds(roundCount: int, playerDecisionProvider: PlayerDecisionProvider): List<BattleEvent>
    + runRounds(roundCount: int, playerDecisionProvider: PlayerDecisionProvider, battleEventListener: BattleEventListener): List<BattleEvent>
    + runUntilBattleEnds(playerDecisionProvider: PlayerDecisionProvider): List<BattleEvent>
    + runUntilBattleEnds(playerDecisionProvider: PlayerDecisionProvider, battleEventListener: BattleEventListener): List<BattleEvent>
    + getLivingEnemies(): List<Combatant>
    + getLivingEnemiesInTurnOrder(): List<Combatant>
  }

  class BattleState <<entity>> {
    - player: PlayerCharacter
    - initialEnemies: List<Combatant> [1..*]
    - reserveEnemies: List<Combatant> [0..*]
    - spawnedEnemies: List<Combatant> [1..*]
    ~ player(): PlayerCharacter
    ~ initialEnemies(): List<Combatant>
    ~ reserveEnemies(): List<Combatant>
    ~ spawnedEnemies(): List<Combatant>
    ~ moveAllReserveToSpawned(): void
    ~ combatantsAliveAtRoundStart(): List<Combatant>
    ~ livingEnemies(): List<Combatant>
    ~ isBattleOver(): boolean
  }

  class BattleEventPublisher <<control>> {
    - events: List<BattleEvent> [0..*]
    ~ emit(battleEvent: BattleEvent, battleEventListener: BattleEventListener): void
    ~ snapshot(): List<BattleEvent>
  }

  interface TurnProcessor <<strategy>> {
    ~ processTurn(roundNumber: int, actor: Combatant, playerDecisionProvider: PlayerDecisionProvider, actionExecutionContext: ActionExecutionContext, emit: Consumer<BattleEvent>): void
  }

  class DefaultTurnProcessor <<control>> {
    - player: PlayerCharacter
    + processTurn(roundNumber: int, actor: Combatant, playerDecisionProvider: PlayerDecisionProvider, actionExecutionContext: ActionExecutionContext, emit: Consumer<BattleEvent>): void
  }

  interface WaveManager <<strategy>> {
    ~ spawnBackupIfNeeded(emit: Consumer<BattleEvent>): void
  }

  class DefaultWaveManager <<control>> {
    - initialEnemies: List<Combatant> [1..*]
    - reserveEnemies: List<Combatant> [0..*]
    - moveReserveToSpawned: Runnable
    + spawnBackupIfNeeded(emit: Consumer<BattleEvent>): void
  }

  interface RoundLifecycle <<strategy>> {
    ~ createRoundSummary(roundNumber: int): RoundSummaryEvent
    ~ completeRound(emit: Consumer<BattleEvent>): void
  }

  class DefaultRoundLifecycle <<control>> {
    - player: PlayerCharacter
    - spawnedEnemies: List<Combatant> [1..*]
    + createRoundSummary(roundNumber: int): RoundSummaryEvent
    + completeRound(emit: Consumer<BattleEvent>): void
  }

  interface BattleOutcomeReporter <<strategy>> {
    ~ reportOutcome(roundsPlayed: int, livingEnemies: List<Combatant>, reserveEnemies: List<Combatant>, emit: Consumer<BattleEvent>): void
  }

  class DefaultBattleOutcomeReporter <<control>> {
    - player: PlayerCharacter
    + reportOutcome(roundsPlayed: int, livingEnemies: List<Combatant>, reserveEnemies: List<Combatant>, emit: Consumer<BattleEvent>): void
  }

  class BattleSetup <<entity>> {
    - player: PlayerCharacter
    - initialEnemies: List<Combatant> [1..*]
    - backupEnemies: List<Combatant> [0..*]
    + getPlayer(): PlayerCharacter
    + getInitialEnemies(): List<Combatant>
    + getBackupEnemies(): List<Combatant>
  }

  class BattleSetupFactory <<factory>> {
    - combatantFactory: CombatantFactory
    + create(configuration: GameConfiguration): BattleSetup
    + createCustom(config: CustomGameConfiguration): BattleSetup
  }

  interface TurnOrderStrategy <<strategy>> {
    + determineOrder(combatants: List<Combatant>): List<Combatant>
  }

  class SpeedTurnOrderStrategy <<strategy>> {
    + determineOrder(combatants: List<Combatant>): List<Combatant>
  }

  interface PlayerDecisionProvider <<strategy>> {
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  class ScriptedDecisionProvider <<strategy>> {
    - decisionsByRound: Map<Integer, PlayerDecision> [0..*]
    + addDecision(roundNumber: int, playerDecision: PlayerDecision): ScriptedDecisionProvider
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  class ScenarioScript <<entity>> {
    - name: String
    - battleSetup: BattleSetup
    - decisionProvider: PlayerDecisionProvider
    - roundCount: int
    + getName(): String
    + getBattleSetup(): BattleSetup
    + getDecisionProvider(): PlayerDecisionProvider
    + getRoundCount(): int
  }

  class AppendixAScenarios <<utility>> {
    {static} +all(): List<ScenarioScript>
    {static} +easyWarrior(): ScenarioScript
    {static} +mediumWarrior(): ScenarioScript
    {static} +mediumWizard(): ScenarioScript
  }

  class EasyLevelSetup <<utility>> {
    {static} +createWarriorPotionSmokeBombSetup(): BattleSetup
  }

  class MediumLevelSetup <<utility>> {
    {static} +createWarriorPowerStonePotionSetup(): BattleSetup
    {static} +createWizardPowerStonePotionSetup(): BattleSetup
  }

  class HardLevelSetup <<utility>> {
    {static} +create(player: PlayerCharacter, inventory: Inventory): BattleSetup
  }

  class GameConfiguration <<record>> {
    - playerType: PlayerType
    - difficultyLevel: DifficultyLevel
    - selectedItems: List<ItemType> [2]
  }

  class CustomGameConfiguration <<record>> {
    - playerType: PlayerType
    - selectedItems: List<ItemType> [2]
    - waves: List<WaveSpec> [1..2]
  }

  class PlayerDecision <<record>> {
    - action: BattleAction
    - targetReference: TargetReference
    {static} +targeted(action: BattleAction, target: Combatant): PlayerDecision
    {static} +targeted(action: BattleAction, targetId: CombatantId): PlayerDecision
    {static} +untargeted(action: BattleAction): PlayerDecision
  }

  class TargetReference <<record>> {
    - type: TargetType
    - combatantId: CombatantId [0..1]
    {static} +none(): TargetReference
    {static} +enemy(combatantId: CombatantId): TargetReference
    {static} +enemy(combatant: Combatant): TargetReference
    +resolveFrom(livingEnemies: List<Combatant>): Combatant
  }

  enum TargetType <<nested>> {
    NONE
    ENEMY
  }

  class WaveSpec <<record>> {
    - enemyCounts: List<EnemyCount> [1..*]
    {static} +of(enemyCounts: EnemyCount...): WaveSpec
    +totalEnemies(): int
    +countOf(enemyFactory: EnemyFactory): int
    +describe(): String
  }

  class EnemyCount <<record>> {
    - enemyFactory: EnemyFactory
    - count: int
    {static} +of(enemyFactory: EnemyFactory, count: int): EnemyCount
    +describe(): String
  }

  interface EnemyFactory <<factory>> {
    + getDisplayName(): String
    + getPluralDisplayName(): String
    + getMaxPerWave(): int
    + create(name: String, combatantFactory: CombatantFactory): EnemyCombatant
    + formatCount(count: int): String
  }

  enum EnemyType <<factory>> {
    GOBLIN
    WOLF
    - displayName: String
    - pluralDisplayName: String
    - maxPerWave: int
    - configurationPrompt: String
    - baseHitPoints: HitPoints
    - baseStats: CombatStats
    + getDisplayName(): String
    + getPluralDisplayName(): String
    + getMaxPerWave(): int
    + getConfigurationPrompt(): String
    + getBaseHitPoints(): HitPoints
    + getBaseStats(): CombatStats
    + create(name: String, combatantFactory: CombatantFactory): EnemyCombatant
  }

  enum PlayerType <<factory>> {
    WARRIOR
    WIZARD
    - displayName: String
    - specialSkillName: String
    - baseHitPoints: HitPoints
    - baseStats: CombatStats
    + getDisplayName(): String
    + getSpecialSkillName(): String
    + getBaseHitPoints(): HitPoints
    + getBaseStats(): CombatStats
    + createPlayer(combatantFactory: CombatantFactory): PlayerCharacter
  }

  enum DifficultyLevel {
    EASY
    MEDIUM
    HARD
    - displayName: String
    - initialSpawnDescription: String
    - backupSpawnDescription: String
    - initialEnemyCount: int
    - backupEnemyCount: int
    + getDisplayName(): String
    + getInitialSpawnDescription(): String
    + getBackupSpawnDescription(): String
    + getInitialEnemyCount(): int
    + getBackupEnemyCount(): int
    + getTotalEnemyCount(): int
  }
}

package "report" {
  interface BattleEvent

  class ActionEvent <<event>> {
    - actorId: CombatantId
    - actorName: String
    - actionName: String
    - targetId: CombatantId
    - targetName: String
    - hpBefore: int
    - hpAfter: int
    - attackerAttack: int
    - targetDefense: int
    - damage: int
    - targetEliminated: boolean
    - statusEffectNotes: List<String> [0..*]
  }

  class NarrationEvent <<event>> {
    - text: String
    + getText(): String
  }

  class RoundStartEvent <<event>> {
    - roundNumber: int
    + getRoundNumber(): int
  }

  class CombatantSummary <<value object>> {
    - combatantId: CombatantId
    - name: String
    - currentHp: int
    - maxHp: int
    - currentAttack: int
    - baseAttack: int
    - alive: boolean
    - activeStatuses: List<String> [0..*]
  }

  class RoundSummaryEvent <<event>> {
    - roundNumber: int
    - playerSummary: CombatantSummary
    - enemySummaries: List<CombatantSummary> [0..*]
    - inventorySnapshot: Map<ItemType, Integer> [0..*]
    - specialSkillCooldown: int
  }

  class SkippedTurnEvent <<event>> {
    - combatantId: CombatantId
    - combatantName: String
    - reason: String
    - statusEffectNotes: List<String> [0..*]
  }

  class StatusEffectReportEvent <<record>> <<event>> {
    - statusEffectNotes: List<String> [0..*]
    {static} +fromStatusEffectOutcomes(statusEffectOutcomes: List<CombatantStatusOutcome>): StatusEffectReportEvent
  }

  class StatusEffectReportMapper <<utility>> {
    {static} ~toNotes(statusEffectOutcomes: List<CombatantStatusOutcome>): List<String>
  }
}

package "ui" {
  class ConsoleBattleUi <<boundary>> {
    - combatantFactory: CombatantFactory
    + showLoadingScreen(): void
    + promptForPlayerType(): PlayerType
    + promptForDifficultyOrCustom(): DifficultyLevel
    + promptForWaveCount(): int
    + promptForWaveSpec(waveNumber: int): WaveSpec
    + promptForItems(itemCount: int): List<ItemType>
    + showConfigurationSummary(configuration: GameConfiguration): void
    + showPlayerTurn(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): void
    + promptForSelection(prompt: String, options: List<String>): int
    + showMessage(message: String): void
    + showBattleTranscript(lines: List<String>): void
    + showBattleLines(lines: List<String>): void
    + promptPostGameChoice(): PostGameChoice
  }

  class BattleConsoleFormatter <<boundary>> {
    + format(events: List<BattleEvent>): List<String>
  }

  class CliPlayerDecisionProvider <<boundary>> {
    - ui: ConsoleBattleUi
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  class TurnBasedArenaCli <<boundary>> {
    - ui: ConsoleBattleUi
    - battleSetupFactory: BattleSetupFactory
    - formatter: BattleConsoleFormatter
    - turnOrderStrategy: TurnOrderStrategy
    + run(): void
    {static} +main(args: String[]): void
  }

  class EasyRoundsDemo <<boundary>> {
    {static} +main(args: String[]): void
  }

  enum PostGameChoice {
    REPLAY
    NEW_GAME
    EXIT
  }
}

package "ui.gui" {
  class TurnBasedArenaGui <<boundary>> {
    - log: JTextArea
    - arenaScene: ArenaScenePanel
    - commandPanel: BattleCommandPanel
    - setupPanel: BattleSetupPanel
    - controller: BattleController
    + TurnBasedArenaGui(setupFactory: BattleSetupFactory)
    + showSetupPreview(): void
    + showBattleLoaded(setup: BattleSetup): void
    + showBattleEvent(event: BattleEvent, battleMessage: String, transcriptLines: List<String>): void
    + showPlayerTurn(turn: PlayerTurnRequest): void
    + selectedEnemyId(): CombatantId
    + selectNextEnemy(direction: int): void
    + askPostGameChoice(): PostGameChoice
    + exitGame(): void
    {static} +main(args: String[]): void
  }

  package "controller" {
    class BattleController <<controller>> {
      - view: BattleView
      - model: BattleSessionModel
      - playbackController: BattlePlaybackController
      - commandResolver: PlayerCommandResolver
      - setupFactory: BattleSetupFactory
      - consoleFormatter: BattleConsoleFormatter
      - dialogueFormatter: BattleDialogueFormatter
      - battleExecutor: ExecutorService
      + startBattle(request: BattleLaunchRequest): void
      ~awaitPlayerDecision(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
      + handleCommand(command: BattleCommandPanel.Command): void
      + shutdown(): void
    }

    class GuiPlayerDecisionProvider <<adapter>> {
      - controller: BattleController
      + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
    }
  }

  package "command" {
    class PlayerCommandResolver <<service>> {
      + resolve(command: BattleCommandPanel.Command, turn: PlayerTurnRequest, selectedTarget: CombatantId): Optional<ResolvedPlayerCommand>
      - createAction(command: BattleCommandPanel.Command): BattleAction
      - isActionAvailable(command: BattleCommandPanel.Command, player: PlayerCharacter): boolean
      - findLivingEnemy(turn: PlayerTurnRequest, selectedTarget: CombatantId): Combatant
    }
  }

  package "model" {
    class BattleSessionModel <<model>> {
      - battleRunning: boolean
      - activePlayerTurn: PlayerTurnRequest
      - queuedPlayerTurn: PlayerTurnRequest
      - queuedPostGameConfig: PostGameConfig
      + beginBattle(): boolean
      + finishBattle(): void
      + stopBattle(): void
      + clearQueuedPlaybackState(): void
      + activePlayerTurn(): Optional<PlayerTurnRequest>
      + clearActivePlayerTurn(): void
      + queuePlayerTurn(turn: PlayerTurnRequest): void
      + takeQueuedPlayerTurn(): Optional<PlayerTurnRequest>
      + queuePostGame(configuration: PostGameConfig): void
      + takeQueuedPostGameConfig(): Optional<PostGameConfig>
    }

    class PlayerTurnRequest <<record>> {
      - roundNumber: int
      - player: PlayerCharacter
      - livingEnemies: List<Combatant>
      - responseQueue: BlockingQueue<PlayerDecision>
    }

    class ResolvedPlayerCommand <<record>> {
      - decision: PlayerDecision
      - actionName: String
      - targetLabel: String
    }
  }

  package "playback" {
    class BattlePlaybackController <<controller>> {
      - events: Queue<BattleEvent>
      - dialogueFormatter: BattleDialogueFormatter
      - eventPlayer: Consumer<BattleEvent>
      - drainedCallback: Runnable
      - playbackTimer: Timer
      - active: boolean
      + enqueue(event: BattleEvent): void
      + playNextIfIdle(): void
      + reset(): void
    }

    class BattleDialogueFormatter <<formatter>> {
      + format(event: BattleEvent): String
      + playbackDelayMillis(event: BattleEvent): int
    }
  }

  package "setup" {
    class BattleLaunchRequest <<request>> {
      - setupCreator: Function<BattleSetupFactory, BattleSetup>
      - replayConfiguration: PostGameConfig
      - intro: String
      {static} +preset(configuration: GameConfiguration): BattleLaunchRequest
      {static} +custom(configuration: CustomGameConfiguration): BattleLaunchRequest
      {static} +replay(configuration: PostGameConfig): BattleLaunchRequest
      + createSetup(setupFactory: BattleSetupFactory): BattleSetup
      + replayConfiguration(): PostGameConfig
      + intro(): String
    }

    interface PostGameConfig <<sealed>> {
      {static} +preset(configuration: GameConfiguration): PostGameConfig
      {static} +custom(configuration: CustomGameConfiguration): PostGameConfig
    }

    class PostGameConfigPreset as "PostGameConfig.Preset" <<record>> {
      - configuration: GameConfiguration
    }

    class PostGameConfigCustom as "PostGameConfig.Custom" <<record>> {
      - configuration: CustomGameConfiguration
    }
  }

  package "util" {
    class SwingThread <<utility>> {
      {static} +runAndWait(task: Runnable): void
    }
  }

  package "view" {
    interface BattleView <<view>> {
      + showSetupPreview(): void
      + setSetupControlsEnabled(enabled: boolean): void
      + clearBattleLog(): void
      + appendLog(line: String): void
      + showBattleLoading(): void
      + showBattleLoaded(setup: BattleSetup): void
      + showBattleEvent(event: BattleEvent, battleMessage: String, transcriptLines: List<String>): void
      + showPlayerTurn(turn: PlayerTurnRequest): void
      + showCommandResolving(actionName: String): void
      + showBattleComplete(): void
      + showBattleError(message: String): void
      + selectedEnemyId(): CombatantId
      + selectNextEnemy(direction: int): void
      + askPostGameChoice(): PostGameChoice
      + exitGame(): void
    }

    class BattleSetupPanel <<view>> {
      - startListener: Consumer<BattleLaunchRequest>
      - layoutChangedListener: Runnable
      - battleRunning: boolean
      + setSetupControlsEnabled(enabled: boolean): void
    }

    class BattleCommandPanel <<view>> {
      - promptLabel: JLabel
      - statsLabel: JLabel
      - targetLabel: JLabel
      - optionButtons: JButton[4]
      - commandListener: Consumer<Command>
      - menuState: MenuState
      - messageTimer: Timer
      + setCommandListener(commandListener: Consumer<Command>): void
      + setIdle(message: String): void
      + showTurn(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>, selectedTargetLabel: String): void
      + updateTarget(selectedTargetLabel: String): void
      + setResolving(actionName: String): void
      + showBattleMessage(message: String): void
      + showBattleComplete(): void
    }

    enum BattleCommandPanelCommand as "BattleCommandPanel.Command" {
      BASIC_ATTACK
      DEFEND
      POTION
      SPECIAL_SKILL
      POWER_STONE
      SMOKE_BOMB
      PREVIOUS_TARGET
      NEXT_TARGET
    }

    class ArenaScenePanel <<view>> {
      - model: ArenaSceneModel
      - renderer: ArenaSceneRenderer
      - sceneLoop: ArenaSceneLoop
      + setTargetSelectionListener(targetSelectionListener: Consumer<String>): void
      + showSetupPreview(): void
      + startBattle(setup: BattleSetup): void
      + showPlayerTurn(currentRound: int, player: PlayerCharacter, livingEnemies: List<Combatant>): void
      + completePlayerTurn(actionName: String): void
      + getSelectedEnemyId(): CombatantId
      + getSelectedEnemyLabel(): String
      + selectNextEnemy(direction: int): void
      + applyBattleEvent(event: BattleEvent): void
    }

    class ArenaSceneModel <<model>> {
      - sprites: Map<CombatantId, FighterSpriteDto>
      - enemyOrder: List<CombatantId>
      - pressedDirections: Set<String>
      - floatingTexts: List<FloatingText>
      - playerId: CombatantId
      - selectedEnemyId: CombatantId
      - banner: String
      - hint: String
      - acceptingPlayerTurn: boolean
      - battleActive: boolean
      ~showSetupPreview(): void
      ~startBattle(setup: BattleSetup, arenaWidth: int, arenaHeight: int): void
      ~showPlayerTurn(currentRound: int, player: PlayerCharacter, livingEnemies: List<Combatant>, arenaWidth: int, arenaHeight: int): void
      ~completePlayerTurn(actionName: String): void
      ~selectedEnemyId(): CombatantId
      ~selectedEnemyLabel(): String
      ~selectNextEnemy(direction: int): void
      ~selectEnemyAt(point: Point): boolean
      ~applyBattleEvent(event: BattleEvent, arenaWidth: int, arenaHeight: int): void
      ~tick(arenaWidth: int, arenaHeight: int): void
      ~spritesByDrawOrder(): List<FighterSpriteDto>
    }

    class ArenaSceneModelFloatingText as "ArenaSceneModel.FloatingText" <<record>> {
      - text: String
      - x: double
      - y: double
      - createdAt: long
      - damage: boolean
    }

    class ArenaSceneLoop <<timer>> {
      - tickCallback: Runnable
      - tickTimer: Timer
      ~start(): void
      ~stop(): void
    }

    class ArenaSceneRenderer <<renderer>> {
      - fighterRenderer: FighterSpriteRenderer
      ~render(g: Graphics2D, model: ArenaSceneModel, width: int, height: int, now: long): void
    }

    class FighterSpriteDto <<dto>> {
      + id: CombatantId
      + player: boolean
      + type: FighterType
      + name: String
      + hp: int
      + maxHp: int
      + attack: int
      + baseAttack: int
      + alive: boolean
      + statuses: List<String>
      + x: double
      + y: double
      + offsetX: double
      + offsetY: double
      + walkPhase: double
      + hurtUntil: long
      + pulseUntil: long
      {static} +fromCombatant(combatant: Combatant, player: boolean): FighterSpriteDto
      {static} +fromSummary(summary: CombatantSummary, player: boolean): FighterSpriteDto
      + updateFrom(combatant: Combatant): void
      + updateFrom(summary: CombatantSummary): void
      + setPlayer(player: boolean): void
      + drawX(): double
      + drawY(): double
      + bounds(): Shape
    }

    enum FighterType {
      WARRIOR
      WIZARD
      GOBLIN
      WOLF
      UNKNOWN
    }

    class FighterSpriteRenderer <<renderer>> {
      - bodyRenderers: Map<FighterType, FighterBodyRenderer>
      - effectRenderer: FighterSpriteEffectRenderer
      - hudRenderer: FighterSpriteHudRenderer
      + render(g: Graphics2D, sprite: FighterSpriteDto, selectedEnemyId: CombatantId): void
      ~bodyRendererFor(sprite: FighterSpriteDto): FighterBodyRenderer
    }

    interface FighterBodyRenderer <<strategy>> {
      ~renderBody(g: Graphics2D, sprite: FighterSpriteDto): void
    }

    class WarriorBodyRenderer <<renderer>>
    class WizardBodyRenderer <<renderer>>
    class GoblinBodyRenderer <<renderer>>
    class WolfBodyRenderer <<renderer>>
    class UnknownFighterBodyRenderer <<renderer>>

    class FighterSpriteEffectRenderer <<renderer>> {
      ~renderPulse(g: Graphics2D, sprite: FighterSpriteDto): void
    }

    class FighterSpriteHudRenderer <<renderer>> {
      ~render(g: Graphics2D, sprite: FighterSpriteDto, centerX: int, baseY: int): void
      {static} ~healthRatio(sprite: FighterSpriteDto): double
    }

    enum GuiPostGameChoice as "PostGameChoice" {
      REPLAY
      NEW_SETUP
      EXIT
    }
  }
