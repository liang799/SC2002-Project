TurnBasedArenaCli "1" *-- "1" ConsoleBattleUi
TurnBasedArenaCli "1" *-- "1" BattleConsoleFormatter
TurnBasedArenaCli "1" --> "1" BattleSetupFactory
TurnBasedArenaCli "1" --> "1" TurnOrderStrategy
