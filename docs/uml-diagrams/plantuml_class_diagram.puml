@startuml
title SC2002 Turn-Based Combat Arena - Layered Class Diagram

left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
hide circle

skinparam class {
  BackgroundColor<<entity>> #E8F4EA
  BackgroundColor<<control>> #EAF0FF
  BackgroundColor<<boundary>> #FFF4D6
  BackgroundColor<<strategy>> #F3E8FF
  BackgroundColor<<factory>> #F0F0F0
  BackgroundColor<<event>> #FDECEC
  BorderColor #333333
  ArrowColor #333333
}

legend right
  Focus: classes and interfaces grouped by layer:
  UI Boundary -> Engine Control -> Domain Entity.
  Includes inheritance, associations, key attributes/methods,
  enumeration types, and OO principle notes.

  Type labels:
  <<interface>>, <<enumeration>>, and <<record>>
  identify non-standard class boxes explicitly.
  Plain rectangles are concrete classes.

  UML notation:
  <|-- inheritance
  <|.. interface implementation
  *-- composition / strong ownership
  o-- aggregation / collection reference
  --> association or dependency

  OO annotations are attached as notes.
endlegend

package "DOMAIN LAYER - domain entities" {
  abstract class Combatant <<abstract>> <<entity>> {
    - combatantId: CombatantId
    - name: String
    - baseStats: CombatStats
    - inventory: Inventory
    - hitPoints: HitPoints
    - statusEffectRegistry: StatusEffectRegistry
    + combatantId(): CombatantId
    + getName(): String
    + getCurrentHp(): int
    + getAttack(): int
    + getDefense(): int
    + getSpeed(): int
    + isAlive(): boolean
    + attack(target: Combatant): AttackResolution
    + receiveDamage(damage: int): void
    + heal(amount: int): void
    + addStatusEffect(effect: StatusEffect): List<CombatantStatusOutcome>
    + completeRound(): List<CombatantStatusOutcome>
  }

  class PlayerCharacter <<entity>> {
    - specialSkill: SpecialSkill
    + canUseSpecialSkill(): boolean
    + useSpecialSkill(context: ActionExecutionContext, target: Combatant): List<BattleEvent>
    + advanceRoundState(): void
  }

  class EnemyCombatant <<entity>> {
    - turnAction: BattleAction
    + takeTurn(context: ActionExecutionContext, target: Combatant): List<BattleEvent>
  }

  class Inventory <<entity>> {
    - itemCounts: Map<ItemType, Integer>
    + add(itemType: ItemType, count: int): void
    + countOf(itemType: ItemType): int
    + use(itemType: ItemType): void
    + snapshot(): Map<ItemType, Integer>
  }

  class SpecialSkill <<entity>> {
    - action: BattleAction
    - cooldownTurns: int
    - cooldownRemaining: int
    + isAvailable(): boolean
    + use(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
    + advanceCooldown(): void
    + triggerCooldown(): void
  }

  class AttackResolution <<record>> <<entity>> {
    - attackUsed: int
    - targetDefense: int
    - hpBefore: int
    - hpAfter: int
    - damage: int
    - targetEliminated: boolean
  }

  class CombatantId <<record>> <<entity>> {
    - value: UUID
    {static} + generate(): CombatantId
  }

  class CombatStats <<record>> <<entity>> {
    - attack: Stat
    - defense: Stat
    - speed: Stat
    + valueOf(statType: StatType): int
    + addFlat(type: StatType, amount: int): CombatStats
    + multiplyBy(type: StatType, factor: double): CombatStats
  }

  class HitPoints <<record>> <<entity>> {
    - current: int
    - max: int
    {static} + full(maxHp: int): HitPoints
    + takeDamage(damage: int): HitPoints
    + heal(amount: int): HitPoints
    + isDead(): boolean
  }

  class Stat <<record>> <<entity>> {
    - value: int
    + addFlat(amount: int): Stat
    + multiplyBy(factor: double): Stat
    + clampMinimum(minimum: int): Stat
  }

  enum ItemType <<enumeration>> {
    POTION
    POWER_STONE
    SMOKE_BOMB
    - displayName: String
    - description: String
    + getDisplayName(): String
    + getDescription(): String
  }

  enum StatType <<enumeration>> {
    ATTACK
    DEFENSE
    SPEED
  }
}

package "DOMAIN LAYER - status effects" {
  interface StatusEffect <<interface>> <<strategy>> {
    + kind(): StatusEffectKind
    + description(): String
    + mergeWith(other: StatusEffect): Optional<StatusEffect>
    + onApply(owner: Combatant): List<StatusEffectOutcome>
    + onRoundEnd(owner: Combatant): List<StatusEffectOutcome>
    + onExpire(owner: Combatant): List<StatusEffectOutcome>
    + modifyStats(stats: CombatStats): CombatStats
    + modifyIncomingDamage(owner: Combatant, attacker: Combatant, damage: int): DamageAdjustment
    + getTurnBlockReason(owner: Combatant): Optional<String>
    + isExpired(): boolean
  }

  class StatusEffectRegistry <<entity>> {
    - effects: List<StatusEffect>
    - pendingOutcomes: List<StatusEffectOutcome>
    + add(owner: Combatant, effect: StatusEffect): List<StatusEffectOutcome>
    + apply(owner: Combatant, stats: CombatStats): CombatStats
    + adjustIncomingDamage(owner: Combatant, attacker: Combatant, damage: int): DamageAdjustment
    + completeRound(owner: Combatant): List<StatusEffectOutcome>
    + activeStatuses(owner: Combatant): List<String>
  }

  class ArcanePowerStatusEffect <<entity>> {
    - attackBonus: int
    + modifyStats(stats: CombatStats): CombatStats
    + mergeWith(other: StatusEffect): Optional<StatusEffect>
  }

  class DefendStatusEffect <<entity>> {
    - roundsRemaining: int
    + modifyStats(stats: CombatStats): CombatStats
    + onRoundEnd(owner: Combatant): List<StatusEffectOutcome>
  }

  class StrengthBoostStatusEffect <<entity>> {
    - attackBonus: int
    - roundsRemaining: int
    + modifyStats(stats: CombatStats): CombatStats
    + onRoundEnd(owner: Combatant): List<StatusEffectOutcome>
  }

  class SmokeBombStatusEffect <<entity>> {
    - chargesRemaining: int
    + modifyIncomingDamage(owner: Combatant, attacker: Combatant, damage: int): DamageAdjustment
  }

  class StunStatusEffect <<entity>> {
    - blockedTurnsRemaining: int
    + getTurnBlockReason(owner: Combatant): Optional<String>
  }

  interface StatusEffectOutcome <<interface>>
  class CombatantStatusOutcome <<record>> <<entity>> {
    - combatantId: CombatantId
    - combatantName: String
    - outcome: StatusEffectOutcome
  }

  class DamageAdjustment <<record>> <<entity>> {
    - damage: int
    - modifiers: List<DamageModifier>
  }

  class DamageModifier <<record>> <<entity>> {
    - source: StatusEffectKind
    - type: DamageModifierType
  }

  class StatusEffectChange <<record>> <<entity>> {
    - source: StatusEffectKind
    - type: StatusEffectChangeType
    - magnitude: int
    - duration: int
  }

  enum StatusEffectKind <<enumeration>> {
    ARCANE_POWER
    DEFEND
    SMOKE_BOMB
    STRENGTH_BOOST
    STUN
  }

  enum DamageModifierType <<enumeration>> {
    BLOCKED
    REDUCED
    INCREASED
  }

  enum StatusEffectChangeType <<enumeration>> {
    APPLIED
    EXPIRED
  }
}

package "DOMAIN LAYER - action strategies" {
  interface ActionExecutionContext <<interface>> {
    + getLivingEnemies(): List<Combatant>
    + getLivingEnemiesInTurnOrder(): List<Combatant>
  }

  interface BattleAction <<interface>> <<strategy>> {
    + getName(): String
    + advancesCooldown(): boolean
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class BasicAttackAction <<strategy>> {
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class DefendAction <<strategy>> {
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class ShieldBashAction <<strategy>> {
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class ArcaneBlastAction <<strategy>> {
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UsePotionAction <<strategy>> {
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UseSmokeBombAction <<strategy>> {
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UseSpecialSkillAction <<strategy>> {
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  class UsePowerStoneSkillAction <<strategy>> {
    + advancesCooldown(): boolean
    + targetingMode(actor: Combatant): TargetingMode
    + execute(context: ActionExecutionContext, actor: Combatant, target: Combatant): List<BattleEvent>
  }

  enum TargetingMode <<enumeration>> {
    NONE
    SINGLE_ENEMY
  }
}

package "ENGINE LAYER - orchestration and setup" {
  class BattleEngine <<control>> {
    - battleState: BattleState
    - turnOrderStrategy: TurnOrderStrategy
    - turnProcessor: TurnProcessor
    - waveManager: WaveManager
    - roundLifecycle: RoundLifecycle
    - battleOutcomeReporter: BattleOutcomeReporter
    + runRounds(roundCount: int, provider: PlayerDecisionProvider): List<BattleEvent>
    + runUntilBattleEnds(provider: PlayerDecisionProvider): List<BattleEvent>
    + getLivingEnemies(): List<Combatant>
    + getLivingEnemiesInTurnOrder(): List<Combatant>
  }

  class BattleState <<entity>> {
    - player: PlayerCharacter
    - initialEnemies: List<Combatant>
    - reserveEnemies: List<Combatant>
    - spawnedEnemies: List<Combatant>
    ~ livingEnemies(): List<Combatant>
    ~ isBattleOver(): boolean
  }

  interface TurnProcessor <<interface>> <<strategy>> {
    ~ processTurn(roundNumber: int, actor: Combatant, provider: PlayerDecisionProvider, context: ActionExecutionContext, emit: Consumer<BattleEvent>): void
  }

  class DefaultTurnProcessor <<control>> {
    - player: PlayerCharacter
    + processTurn(roundNumber: int, actor: Combatant, provider: PlayerDecisionProvider, context: ActionExecutionContext, emit: Consumer<BattleEvent>): void
  }

  interface WaveManager <<interface>> <<strategy>> {
    ~ spawnBackupIfNeeded(emit: Consumer<BattleEvent>): void
  }

  class DefaultWaveManager <<control>> {
    - initialEnemies: List<Combatant>
    - reserveEnemies: List<Combatant>
    - moveReserveToSpawned: Runnable
    + spawnBackupIfNeeded(emit: Consumer<BattleEvent>): void
  }

  interface RoundLifecycle <<interface>> <<strategy>> {
    ~ createRoundSummary(roundNumber: int): RoundSummaryEvent
    ~ completeRound(emit: Consumer<BattleEvent>): void
  }

  class DefaultRoundLifecycle <<control>> {
    - player: PlayerCharacter
    - spawnedEnemies: List<Combatant>
    + createRoundSummary(roundNumber: int): RoundSummaryEvent
    + completeRound(emit: Consumer<BattleEvent>): void
  }

  interface BattleOutcomeReporter <<interface>> <<strategy>> {
    ~ reportOutcome(roundsPlayed: int, livingEnemies: List<Combatant>, reserveEnemies: List<Combatant>, emit: Consumer<BattleEvent>): void
  }

  class DefaultBattleOutcomeReporter <<control>> {
    - player: PlayerCharacter
    + reportOutcome(roundsPlayed: int, livingEnemies: List<Combatant>, reserveEnemies: List<Combatant>, emit: Consumer<BattleEvent>): void
  }

  interface TurnOrderStrategy <<interface>> <<strategy>> {
    + determineOrder(combatants: List<Combatant>): List<Combatant>
  }

  class SpeedTurnOrderStrategy <<strategy>> {
    + determineOrder(combatants: List<Combatant>): List<Combatant>
  }

  interface PlayerDecisionProvider <<interface>> <<strategy>> {
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  class ScriptedDecisionProvider <<control>> {
    - decisionsByRound: Map<Integer, PlayerDecision>
    + addDecision(roundNumber: int, decision: PlayerDecision): ScriptedDecisionProvider
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  interface BattleEventListener <<interface>> <<observer>> {
    + onEvent(event: BattleEvent): void
  }

  class BattleSetupFactory <<control>> <<factory>> {
    - combatantFactory: CombatantFactory
    + create(configuration: GameConfiguration): BattleSetup
    + createCustom(config: CustomGameConfiguration): BattleSetup
  }

  class BattleSetup <<entity>> {
    - player: PlayerCharacter
    - initialEnemies: List<Combatant>
    - backupEnemies: List<Combatant>
  }

  class GameConfiguration <<record>> <<entity>> {
    - playerType: PlayerType
    - difficultyLevel: DifficultyLevel
    - selectedItems: List<ItemType>
  }

  class CustomGameConfiguration <<record>> <<entity>> {
    - playerType: PlayerType
    - selectedItems: List<ItemType>
    - waves: List<WaveSpec>
  }

  class PlayerDecision <<record>> <<entity>> {
    - action: BattleAction
    - targetReference: TargetReference
  }

  class TargetReference <<record>> <<entity>> {
    - type: TargetType
    - combatantId: CombatantId
    + resolveFrom(livingEnemies: List<Combatant>): Combatant
  }

  enum TargetType <<enumeration>> {
    NONE
    ENEMY
  }

  class WaveSpec <<record>> <<entity>> {
    - enemyCounts: List<EnemyCount>
    + totalEnemies(): int
  }

  class EnemyCount <<record>> <<entity>> {
    - enemyFactory: EnemyFactory
    - count: int
  }

  interface EnemyFactory <<interface>> <<factory>> {
    + create(name: String, combatantFactory: CombatantFactory): EnemyCombatant
  }

  enum EnemyType <<enumeration>> <<factory>> {
    GOBLIN
    WOLF
    - displayName: String
    - maxPerWave: int
    - baseHitPoints: HitPoints
    - baseStats: CombatStats
    + create(name: String, combatantFactory: CombatantFactory): EnemyCombatant
  }

  enum PlayerType <<enumeration>> <<factory>> {
    WARRIOR
    WIZARD
    - displayName: String
    - specialSkillName: String
    - baseHitPoints: HitPoints
    - baseStats: CombatStats
    + createPlayer(combatantFactory: CombatantFactory): PlayerCharacter
  }

  enum DifficultyLevel <<enumeration>> {
    EASY
    MEDIUM
    HARD
    - displayName: String
    - initialEnemyCount: int
    - backupEnemyCount: int
    + getTotalEnemyCount(): int
  }
}

package "ENGINE LAYER - factories/bootstrap" {
  interface CombatantFactory <<interface>> <<factory>> {
    + createPlayer(playerType: PlayerType): PlayerCharacter
    + createEnemy(enemyType: EnemyType, name: String): EnemyCombatant
  }

  class DefaultCombatantFactory <<factory>> <<control>> {
    - statusEffectRegistryFactory: StatusEffectRegistryFactory
    - playerCreators: Map<PlayerType, PlayerCharacterCreator>
    - enemyCreators: Map<EnemyType, EnemyCombatantCreator>
    + createPlayer(playerType: PlayerType): PlayerCharacter
    + createEnemy(enemyType: EnemyType, name: String): EnemyCombatant
  }

  interface PlayerCharacterCreator <<interface>> <<factory>> {
    + create(statusEffectRegistry: StatusEffectRegistry): PlayerCharacter
  }

  interface EnemyCombatantCreator <<interface>> <<factory>> {
    + create(name: String, statusEffectRegistry: StatusEffectRegistry): EnemyCombatant
  }

  interface SpecialSkillFactory <<interface>> <<factory>> {
    + create(): SpecialSkill
  }

  class DefaultSpecialSkillFactory <<factory>> <<control>> {
    - action: BattleAction
    - cooldownTurns: int
    + create(): SpecialSkill
  }

  interface StatusEffectRegistryFactory <<interface>> <<factory>> {
    + create(): StatusEffectRegistry
  }

  class DefaultStatusEffectRegistryFactory <<factory>> <<control>> {
    - statusEffectRegistrySupplier: Supplier<StatusEffectRegistry>
    + create(): StatusEffectRegistry
  }

  class CombatantFactories <<factory>> <<control>> {
    {static} + createDefault(...): CombatantFactory
  }
}

package "ENGINE LAYER - report events" {
  interface BattleEvent <<interface>> <<event>>

  class ActionEvent <<event>> {
    - actorId: CombatantId
    - actorName: String
    - actionName: String
    - targetId: CombatantId
    - targetName: String
    - damage: int
    - targetEliminated: boolean
  }

  class RoundStartEvent <<event>> {
    - roundNumber: int
    + getRoundNumber(): int
  }

  class RoundSummaryEvent <<event>> {
    - roundNumber: int
    - playerSummary: CombatantSummary
    - enemySummaries: List<CombatantSummary>
    - inventorySnapshot: Map<ItemType, Integer>
  }

  class SkippedTurnEvent <<event>> {
    - combatantId: CombatantId
    - combatantName: String
    - reason: String
    - statusEffectNotes: List<String>
  }

  class StatusEffectReportEvent <<record>> <<event>> {
    - statusEffectNotes: List<String>
    {static} + fromStatusEffectOutcomes(outcomes: List<CombatantStatusOutcome>): StatusEffectReportEvent
  }

  class NarrationEvent <<event>> {
    - text: String
    + getText(): String
  }

  class CombatantSummary <<record>> <<entity>> {
    - combatantId: CombatantId
    - name: String
    - currentHp: int
    - maxHp: int
    - currentAttack: int
    - baseAttack: int
    - alive: boolean
    - activeStatuses: List<String>
  }
}

package "UI LAYER - CLI boundary" {
  class TurnBasedArenaCli <<boundary>> {
    - ui: ConsoleBattleUi
    - battleSetupFactory: BattleSetupFactory
    - formatter: BattleConsoleFormatter
    - turnOrderStrategy: TurnOrderStrategy
    + run(): void
  }

  class ConsoleBattleUi <<boundary>> {
    + promptForPlayerType(): PlayerType
    + promptForDifficultyOrCustom(): DifficultyLevel
    + promptForWaveSpec(waveNumber: int): WaveSpec
    + promptForItems(itemCount: int): List<ItemType>
    + showBattleTranscript(lines: List<String>): void
    + promptPostGameChoice(): PostGameChoice
  }

  class BattleConsoleFormatter <<boundary>> {
    + format(events: List<BattleEvent>): List<String>
  }

  class CliPlayerDecisionProvider <<boundary>> {
    - ui: ConsoleBattleUi
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  enum PostGameChoice <<enumeration>> {
    REPLAY
    NEW_GAME
    EXIT
  }
}

package "UI LAYER - Swing GUI boundary/control" {
  class TurnBasedArenaGui <<boundary>> {
    - controller: BattleController
    - setupPanel: BattleSetupPanel
    - arenaScene: ArenaScenePanel
    - commandPanel: BattleCommandPanel
  }

  interface BattleView <<interface>> <<boundary>> {
    + showSetupPreview(): void
    + showBattleLoaded(setup: BattleSetup): void
    + showBattleEvent(event: BattleEvent, message: String, transcriptLines: List<String>): void
    + showPlayerTurn(turn: PlayerTurnRequest): void
    + selectedEnemyId(): CombatantId
  }

  class BattleSetupPanel <<boundary>> {
    - startListener: Consumer<BattleLaunchRequest>
    - layoutChangedListener: Runnable
    - battleRunning: boolean
    + setSetupControlsEnabled(enabled: boolean): void
  }

  class ArenaScenePanel <<boundary>> {
    - model: ArenaSceneModel
    - renderer: ArenaSceneRenderer
    - sceneLoop: ArenaSceneLoop
    + showSetupPreview(): void
    + startBattle(setup: BattleSetup): void
    + showPlayerTurn(round: int, player: PlayerCharacter, livingEnemies: List<Combatant>): void
    + applyBattleEvent(event: BattleEvent): void
  }

  class BattleCommandPanel <<boundary>> {
    - promptLabel: JLabel
    - optionButtons: JButton[]
    - commandListener: Consumer<BattleCommandPanel.Command>
    + showTurn(round: int, player: PlayerCharacter, livingEnemies: List<Combatant>, selectedTargetLabel: String): void
    + updateTarget(selectedTargetLabel: String): void
    + setResolving(actionName: String): void
  }

  enum BattleCommand as "BattleCommandPanel.Command" <<enumeration>> {
    BASIC_ATTACK
    DEFEND
    POTION
    SPECIAL_SKILL
    POWER_STONE
    SMOKE_BOMB
    PREVIOUS_TARGET
    NEXT_TARGET
  }

  enum GuiPostGameChoice as "gui.PostGameChoice" <<enumeration>> {
    REPLAY
    NEW_SETUP
    EXIT
  }

  class BattleController <<control>> {
    - view: BattleView
    - model: BattleSessionModel
    - playbackController: BattlePlaybackController
    - commandResolver: PlayerCommandResolver
    - setupFactory: BattleSetupFactory
    + startBattle(request: BattleLaunchRequest): void
    + handleCommand(command: BattleCommandPanel.Command): void
  }

  class GuiPlayerDecisionProvider <<control>> {
    - controller: BattleController
    + decide(roundNumber: int, player: PlayerCharacter, livingEnemies: List<Combatant>): PlayerDecision
  }

  class PlayerCommandResolver <<control>> {
    + resolve(command: BattleCommandPanel.Command, turn: PlayerTurnRequest, selectedTarget: CombatantId): Optional<ResolvedPlayerCommand>
  }

  class BattleSessionModel <<entity>> {
    - battleRunning: boolean
    - activePlayerTurn: PlayerTurnRequest
    - queuedPlayerTurn: PlayerTurnRequest
    + beginBattle(): boolean
    + finishBattle(): void
    + queuePlayerTurn(turn: PlayerTurnRequest): void
    + takeQueuedPlayerTurn(): Optional<PlayerTurnRequest>
  }

  class BattlePlaybackController <<control>> {
    - events: Queue<BattleEvent>
    - dialogueFormatter: BattleDialogueFormatter
    - playbackTimer: Timer
    - active: boolean
    + enqueue(event: BattleEvent): void
    + playNextIfIdle(): void
    + reset(): void
  }

  class BattleDialogueFormatter <<control>> {
    + format(event: BattleEvent): String
    + playbackDelayMillis(event: BattleEvent): int
  }

  class BattleLaunchRequest <<entity>> {
    - setupCreator: Function<BattleSetupFactory, BattleSetup>
    - replayConfiguration: PostGameConfig
    - intro: String
    {static} + preset(configuration: GameConfiguration): BattleLaunchRequest
    {static} + custom(configuration: CustomGameConfiguration): BattleLaunchRequest
    {static} + replay(configuration: PostGameConfig): BattleLaunchRequest
    + createSetup(setupFactory: BattleSetupFactory): BattleSetup
  }

  class PlayerTurnRequest <<record>> <<entity>> {
    - roundNumber: int
    - player: PlayerCharacter
    - livingEnemies: List<Combatant>
    - responseQueue: BlockingQueue<PlayerDecision>
  }

  class ResolvedPlayerCommand <<record>> <<entity>> {
    - decision: PlayerDecision
    - actionName: String
    - targetLabel: String
  }
}

' Domain inheritance and composition
Combatant <|-- PlayerCharacter
Combatant <|-- EnemyCombatant
Combatant "1" *-- "1" CombatantId : id
Combatant "1" *-- "1" HitPoints : hp
Combatant "1" *-- "1" Inventory : inventory
Combatant "1" *-- "1" CombatStats : baseStats
Combatant "1" *-- "1" StatusEffectRegistry : status effects
PlayerCharacter "1" *-- "1" SpecialSkill : specialSkill
EnemyCombatant "1" --> "1" BattleAction : turnAction
SpecialSkill "1" --> "1" BattleAction : action
CombatStats "1" *-- "3" Stat : attack/defense/speed
CombatStats --> StatType
Inventory --> ItemType
AttackResolution --> CombatantStatusOutcome

' Status effect model
StatusEffectRegistry "1" *-- "0..*" StatusEffect : active effects
StatusEffect <|.. ArcanePowerStatusEffect
StatusEffect <|.. DefendStatusEffect
StatusEffect <|.. StrengthBoostStatusEffect
StatusEffect <|.. SmokeBombStatusEffect
StatusEffect <|.. StunStatusEffect
StatusEffectOutcome <|.. DamageModifier
StatusEffectOutcome <|.. StatusEffectChange
CombatantStatusOutcome "1" *-- "1" CombatantId
CombatantStatusOutcome "1" *-- "1" StatusEffectOutcome
DamageAdjustment "1" *-- "0..*" DamageModifier
DamageModifier --> StatusEffectKind
DamageModifier --> DamageModifierType
StatusEffectChange --> StatusEffectKind
StatusEffectChange --> StatusEffectChangeType

' Action polymorphism
BattleAction <|.. BasicAttackAction
BattleAction <|.. DefendAction
BattleAction <|.. ShieldBashAction
BattleAction <|.. ArcaneBlastAction
BattleAction <|.. UsePotionAction
BattleAction <|.. UseSmokeBombAction
BattleAction <|.. UseSpecialSkillAction
BattleAction <|.. UsePowerStoneSkillAction
BattleAction --> TargetingMode
ActionExecutionContext <|.. BattleEngine
DefendAction ..> DefendStatusEffect
ShieldBashAction ..> StunStatusEffect
ArcaneBlastAction ..> ArcanePowerStatusEffect
UseSmokeBombAction ..> SmokeBombStatusEffect
UseSpecialSkillAction ..> PlayerCharacter
UsePowerStoneSkillAction ..> PlayerCharacter

' Engine control and setup
BattleEngine "1" *-- "1" BattleState
BattleEngine "1" --> "1" TurnOrderStrategy
BattleEngine "1" --> "1" TurnProcessor
BattleEngine "1" --> "1" WaveManager
BattleEngine "1" --> "1" RoundLifecycle
BattleEngine "1" --> "1" BattleOutcomeReporter
BattleEngine ..> PlayerDecisionProvider
BattleEngine ..> BattleEventListener
BattleEngine ..> BattleEvent
BattleState "1" o-- "1" PlayerCharacter
BattleState "1" o-- "1..*" Combatant : enemies
TurnProcessor <|.. DefaultTurnProcessor
WaveManager <|.. DefaultWaveManager
RoundLifecycle <|.. DefaultRoundLifecycle
BattleOutcomeReporter <|.. DefaultBattleOutcomeReporter
TurnOrderStrategy <|.. SpeedTurnOrderStrategy
PlayerDecisionProvider <|.. ScriptedDecisionProvider
PlayerDecisionProvider <|.. CliPlayerDecisionProvider
PlayerDecisionProvider <|.. GuiPlayerDecisionProvider

BattleSetupFactory --> CombatantFactory
BattleSetup "1" *-- "1" PlayerCharacter
BattleSetup "1" *-- "1..*" Combatant : initial enemies
BattleSetup "1" *-- "0..*" Combatant : backup enemies
GameConfiguration --> PlayerType
GameConfiguration --> DifficultyLevel
GameConfiguration --> ItemType
CustomGameConfiguration --> PlayerType
CustomGameConfiguration --> ItemType
CustomGameConfiguration "1" *-- "1..2" WaveSpec
WaveSpec "1" *-- "1..*" EnemyCount
EnemyCount --> EnemyFactory
EnemyFactory <|.. EnemyType
PlayerDecision --> BattleAction
PlayerDecision *-- TargetReference
TargetReference --> TargetType
TargetReference --> CombatantId

' Factory construction
CombatantFactory <|.. DefaultCombatantFactory
SpecialSkillFactory <|.. DefaultSpecialSkillFactory
StatusEffectRegistryFactory <|.. DefaultStatusEffectRegistryFactory
DefaultCombatantFactory --> StatusEffectRegistryFactory
DefaultCombatantFactory o-- PlayerCharacterCreator
